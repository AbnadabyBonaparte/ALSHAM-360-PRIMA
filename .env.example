# ================================================
# 🚀 ALSHAM 360° PRIMA - Variáveis de Ambiente
# ================================================
# Copie este arquivo para `.env` na raiz do projeto
# e preencha os valores reais.
# NUNCA commite `.env` (já está no .gitignore).
# ================================================

# 🌍 Ambiente
NODE_ENV=production        # development | production | test
PORT=3000                  # Railway define automático

# ================================================
# 🗄️ Supabase
# ================================================
# URL do projeto (ex: https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# 🔑 Chave pública (anon) - segura para frontend
SUPABASE_ANON_KEY=coloque_sua_chave_anon_aqui

# 🔑 Chave service_role (somente backend, nunca expor)
SUPABASE_SERVICE_ROLE=coloque_sua_chave_service_role_aqui

# Para compatibilidade com Vite (frontend)
VITE_SUPABASE_URL=${SUPABASE_URL}
VITE_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ================================================
# 🧠 Inteligência Artificial
# ================================================
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=coloque_sua_chave_openai_aqui

# ================================================
# 🔄 Cache / Redis (opcional)
# ================================================
# Formato: redis://default:password@host:port
REDIS_URL=redis://default:senha@host:6379

# ================================================
# 🛡️ Segurança / Rate Limiting
# ================================================
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=900000   # 15min em ms

# ================================================
# 📊 Analytics / Monitoramento (opcional)
# ================================================
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=your_posthog_key_here

# ================================================
# 🐛 Error Tracking (Sentry)
# ================================================
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ================================================
# 🔗 Integrações externas
# ================================================
N8N_WEBHOOK_URL=
CUSTOM_API_KEY=

# ================================================
# 🚀 Deploy / Domínios
# ================================================
APP_BASE_URL=https://app.alshamglobal.com.br
RAILWAY_STATIC_URL=app.alshamglobal.com.br

# ================================================
# 🔧 Avançado
# ================================================
DB_TIMEOUT=30             # segundos
MAX_PAYLOAD_SIZE=10       # MB
LOG_LEVEL=info            # error | warn | info | debug
